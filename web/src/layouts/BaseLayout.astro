---
import "../styles/global.css";
import SearchBar from "../components/SearchBar.tsx";
import GraphView from "../components/GraphView.tsx";

const API = "http://localhost:3001";
const graphRes = await fetch(`${API}/api/graph`);
const graphData = await graphRes.json();
const graph = Array.isArray(graphData?.nodes) ? graphData : { nodes: [], edges: [] };

interface TocItem {
  level: string;
  text: string;
  anchor: string;
}

interface Props {
  title: string;
  notes?: { slug: string; title: string; tags?: string[] }[];
  currentSlug?: string;
  currentPage?: "notes" | "graph";
  withMath?: boolean;
  toc?: TocItem[];
  backlinks?: { slug: string; title: string }[];
}
const { title, notes = [], currentSlug, currentPage, withMath, toc = [], backlinks = [] } = Astro.props;

const isGraphPage = currentPage === "graph";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title} — MY-CRATE</title>
    <link href="https://api.fontshare.com/v2/css?f[]=satoshi@400,500,700,800&display=swap" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/commit-mono@1.143/fonts/commit-mono.css" rel="stylesheet" />
    {withMath && (
      <>
        <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/katex@0.16.9/dist/katex.min.css" />
        <script defer src="https://cdn.jsdelivr.net/npm/katex@0.16.9/dist/katex.min.js" />
        <script defer src="https://cdn.jsdelivr.net/npm/katex@0.16.9/dist/contrib/auto-render.min.js" />
      </>
    )}
  </head>
  <body>
    <!-- Mobile hamburger -->
    <button type="button" id="sidebar-toggle" class="mobile-hamburger" aria-label="Toggle sidebar">
      <svg id="icon-menu" width="16" height="16" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
      <svg id="icon-close" width="16" height="16" fill="none" stroke="currentColor" viewBox="0 0 24 24" style="display:none;">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M6 18L18 6M6 6l12 12" />
      </svg>
    </button>

    <!-- Mobile overlay -->
    <div id="sidebar-overlay" class="mobile-overlay" aria-hidden="true"></div>

    <!-- ─── Centered Three-Column Layout ─── -->
    <div class="layout-container">
      <!-- Left Sidebar -->
      <aside id="sidebar" class="sidebar-left">
        <a href="/" class="sidebar-logo">
          <svg width="18" height="18" viewBox="0 0 18 18" fill="none" xmlns="http://www.w3.org/2000/svg">
            <circle cx="9" cy="9" r="3" fill="#FFD000" />
            <line x1="9" y1="9" x2="9" y2="3" stroke="#FFD000" stroke-width="1.5" />
            <line x1="9" y1="9" x2="3.8" y2="12" stroke="#FFD000" stroke-width="1.5" />
            <line x1="9" y1="9" x2="14.2" y2="12" stroke="#FFD000" stroke-width="1.5" />
            <circle cx="9" cy="3" r="1.5" fill="#FFD000" />
            <circle cx="3.8" cy="12" r="1.5" fill="#FFD000" />
            <circle cx="14.2" cy="12" r="1.5" fill="#FFD000" />
          </svg>
          <span class="sidebar-logo-text">MY-CRATE</span>
        </a>

        <nav>
          <a href="/" class={`nav-link ${currentPage !== "graph" ? "active" : ""}`}>notes</a>
          <a href="/graph" class={`nav-link ${currentPage === "graph" ? "active" : ""}`}>graph</a>
        </nav>

        <hr class="sidebar-divider" />
        <SearchBar client:load />
        <hr class="sidebar-divider" />

        {notes.length > 0 && (
          <div style="flex: 1; overflow-y: auto; min-height: 0;">
            <p class="section-label" style="margin-bottom: 8px;">Explorer</p>
            <ul style="list-style: none;">
              {notes.map((note: { slug: string; title: string }) => (
                <li>
                  <a
                    href={`/notes/${note.slug}`}
                    class={`explorer-item ${currentSlug === note.slug ? "active" : ""}`}
                  >
                    {note.title}
                  </a>
                </li>
              ))}
            </ul>
          </div>
        )}
      </aside>

      <!-- Main Content -->
      <main class="main-content">
        <div class="page-content">
          <slot />
        </div>
      </main>

      <!-- Right Sidebar -->
      {!isGraphPage && (
        <aside class="sidebar-right">
          {toc.length > 0 && (
            <div>
              <p class="section-label" style="margin-bottom: 8px;">On this page</p>
              <nav>
                {toc.map((item: TocItem) => (
                  <a
                    href={`#${item.anchor}`}
                    class="toc-link"
                    style={item.level === "H3" ? "padding-left: 12px;" : ""}
                  >
                    {item.text}
                  </a>
                ))}
              </nav>
            </div>
          )}

          {toc.length > 0 && <hr class="sidebar-divider" />}

          <div>
            <p class="section-label" style="margin-bottom: 8px;">Graph</p>
            <div style="height: 150px; background: var(--bg-elevated); border: 1px solid var(--border); border-radius: 3px; overflow: hidden;">
              <GraphView client:load nodes={graph?.nodes ?? []} edges={graph?.edges ?? []} currentSlug={currentSlug} />
            </div>
          </div>

          {currentSlug && (
            <>
              <hr class="sidebar-divider" />
              <div>
                <p class="section-label" style="margin-bottom: 8px;">Backlinks</p>
                {backlinks.length > 0 ? (
                  <nav>
                    {backlinks.map((b: { slug: string; title: string }) => (
                      <a href={`/notes/${b.slug}`} class="backlink-item">{b.title}</a>
                    ))}
                  </nav>
                ) : (
                  <p style="font-family: var(--font-mono); font-size: 11px; color: var(--text-faint);">no backlinks</p>
                )}
              </div>
            </>
          )}
        </aside>
      )}
    </div>

    <!-- Sidebar toggle (mobile) -->
    <script is:inline>
      (function () {
        var toggle = document.getElementById("sidebar-toggle");
        var sidebar = document.getElementById("sidebar");
        var overlay = document.getElementById("sidebar-overlay");
        var iconMenu = document.getElementById("icon-menu");
        var iconClose = document.getElementById("icon-close");

        function open() {
          sidebar.classList.add("open");
          overlay.style.opacity = "1";
          overlay.style.pointerEvents = "auto";
          iconMenu.style.display = "none";
          iconClose.style.display = "block";
        }
        function close() {
          sidebar.classList.remove("open");
          overlay.style.opacity = "0";
          overlay.style.pointerEvents = "none";
          iconMenu.style.display = "block";
          iconClose.style.display = "none";
        }
        toggle?.addEventListener("click", function () {
          sidebar.classList.contains("open") ? close() : open();
        });
        overlay?.addEventListener("click", close);
      })();
    </script>

    <!-- TOC scroll spy -->
    {toc.length > 0 && (
      <script is:inline>
        (function () {
          var links = document.querySelectorAll('.toc-link');
          var items = [];
          links.forEach(function (link) {
            var id = link.getAttribute('href');
            if (id) {
              var el = document.getElementById(id.slice(1));
              if (el) items.push({ el: el, link: link });
            }
          });
          function update() {
            var current = items[0];
            for (var i = 0; i < items.length; i++) {
              if (items[i].el.getBoundingClientRect().top <= 100) current = items[i];
            }
            links.forEach(function (l) { l.classList.remove('toc-active'); });
            if (current) current.link.classList.add('toc-active');
          }
          window.addEventListener('scroll', update, { passive: true });
          update();
        })();
      </script>
    )}

    <!-- KaTeX -->
    {withMath && (
      <script is:inline>
        (function () {
          var opts = {
            delimiters: [
              { left: "$$", right: "$$", display: true },
              { left: "$", right: "$", display: false },
            ],
            throwOnError: false,
          };
          function run() {
            var el = document.querySelector(".note-content");
            if (el && typeof renderMathInElement === "function") {
              renderMathInElement(el, opts);
              return;
            }
            setTimeout(run, 30);
          }
          if (document.readyState === "loading") document.addEventListener("DOMContentLoaded", run);
          else run();
        })();
      </script>
    )}
  </body>
</html>
