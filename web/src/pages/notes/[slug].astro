---
export const prerender = false;

import BaseLayout from "../../layouts/BaseLayout.astro";

const { slug } = Astro.params;
const API = "http://localhost:3001";
const [noteRes, notesRes, backlinksRes] = await Promise.all([
  fetch(`${API}/api/notes/${slug}`),
  fetch(`${API}/api/notes`),
  fetch(`${API}/api/notes/${slug}/backlinks`),
]);
const note = await noteRes.json();
const notes = await notesRes.json();
const backlinks = await backlinksRes.json();

if (noteRes.status === 404 || note.error) {
  return new Response(null, { status: 404, statusText: "Not found" });
}
---

<BaseLayout title={note.title} notes={notes} currentSlug={slug} withMath={true} toc={note.toc ?? []}>
  <article
    class="prose prose-neutral prose-invert max-w-none prose-headings:font-semibold prose-a:text-amber-400 prose-a:no-underline hover:prose-a:underline prose-pre:bg-neutral-900 prose-pre:border prose-pre:border-neutral-800"
  >
    {note.tags?.length > 0 && (
      <header class="not-prose mb-6">
        <div class="flex flex-wrap gap-2">
          {note.tags.map((tag: string) => (
            <a
              href={`/tags/${tag}`}
              class="text-xs px-2.5 py-1 rounded-md bg-amber-500/20 text-amber-400 border border-amber-500/30 hover:bg-amber-500/30 hover:border-amber-500/50 transition-colors"
            >
              {tag}
            </a>
          ))}
        </div>
      </header>
    )}
    <div class="note-content" set:html={note.html} />

    {Array.isArray(backlinks) && backlinks.length > 0 && (
      <section class="not-prose mt-12 pt-8 border-t border-neutral-800">
        <h2 class="text-sm font-medium text-neutral-500 uppercase tracking-wider mb-3">Linked from</h2>
        <ul class="space-y-1">
          {backlinks.map((b: { slug: string; title: string }) => (
            <li>
              <a href={`/notes/${b.slug}`} class="text-amber-400 hover:text-amber-300 hover:underline transition-colors">
                {b.title}
              </a>
            </li>
          ))}
        </ul>
      </section>
    )}
  </article>
</BaseLayout>
