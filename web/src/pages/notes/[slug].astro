---
export const prerender = false;

import BaseLayout from "../../layouts/BaseLayout.astro";

const { slug } = Astro.params;
const API = "http://localhost:3001";
const [noteRes, notesRes, backlinksRes] = await Promise.all([
  fetch(`${API}/api/notes/${slug}`),
  fetch(`${API}/api/notes`),
  fetch(`${API}/api/notes/${slug}/backlinks`),
]);
const note = await noteRes.json();
const notes = await notesRes.json();
const backlinks = await backlinksRes.json();

if (noteRes.status === 404 || note.error) {
  return new Response(null, { status: 404, statusText: "Not found" });
}

const wordCount = note.raw_md ? note.raw_md.split(/\s+/).length : (note.html ? note.html.replace(/<[^>]*>/g, '').split(/\s+/).length : 0);
const readingTime = Math.max(1, Math.ceil(wordCount / 200));
---

<BaseLayout title={note.title} notes={notes} currentSlug={slug} withMath={true} toc={note.toc ?? []}>
  <div id="reading-progress"></div>

  <article>
    <!-- Title -->
    <h1 style="font-family: var(--font-display); font-weight: 800; font-size: 2rem; letter-spacing: -0.03em; line-height: 1.15; color: var(--color-text); margin: 0 0 12px;">
      {note.title}
    </h1>

    <!-- Metadata: tags + reading time -->
    <div class="flex items-center gap-3 flex-wrap" style="margin-bottom: 16px;">
      {note.tags?.length > 0 && (
        <span class="flex gap-2">
          {note.tags.map((tag: string) => (
            <a
              href={`/tags/${tag}`}
              style="font-family: var(--font-body); font-size: 12px; color: var(--color-accent); text-decoration: none;"
            >
              #{tag}
            </a>
          ))}
        </span>
      )}
      <span style="font-family: var(--font-body); font-size: 12px; color: var(--color-text-muted);">
        {readingTime} min read
      </span>
    </div>

    <!-- Separator -->
    <div style="border-top: 1px solid var(--color-border); margin-bottom: 32px;"></div>

    <!-- Content -->
    <div class="prose-crate note-content" set:html={note.html} />

    <!-- Backlinks -->
    {Array.isArray(backlinks) && backlinks.length > 0 && (
      <section style="border-top: 1px solid var(--color-border); margin-top: 48px; padding-top: 24px;">
        <p class="section-label mb-3">Linked from</p>
        <div class="flex flex-col gap-1.5">
          {backlinks.map((b: { slug: string; title: string }) => (
            <a
              href={`/notes/${b.slug}`}
              style="font-family: var(--font-body); font-size: 13px; color: var(--color-accent); text-decoration: none; transition: text-shadow 150ms ease-out;"
              class="hover:underline hover:drop-shadow-[0_0_8px_var(--color-accent-border)]"
            >
              {b.title}
            </a>
          ))}
        </div>
      </section>
    )}
  </article>

  <script is:inline>
    (function () {
      var bar = document.getElementById("reading-progress");
      if (!bar) return;
      function update() {
        var docH = document.documentElement.scrollHeight - window.innerHeight;
        var pct = docH > 0 ? (window.scrollY / docH) * 100 : 0;
        bar.style.width = pct + "%";
      }
      window.addEventListener("scroll", update, { passive: true });
      update();
    })();
  </script>
</BaseLayout>
