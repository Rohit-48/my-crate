---
export const prerender = false;

import BaseLayout from "../../layouts/BaseLayout.astro";

const { slug } = Astro.params;
const API = "http://localhost:3001";
const [noteRes, notesRes, backlinksRes] = await Promise.all([
  fetch(`${API}/api/notes/${slug}`),
  fetch(`${API}/api/notes`),
  fetch(`${API}/api/notes/${slug}/backlinks`),
]);
const note = await noteRes.json();
const notes = await notesRes.json();
const backlinks = await backlinksRes.json();

if (noteRes.status === 404 || note.error) {
  return new Response(null, { status: 404, statusText: "Not found" });
}

const wordCount = note.raw_md ? note.raw_md.split(/\s+/).length : (note.html ? note.html.replace(/<[^>]*>/g, '').split(/\s+/).length : 0);
const readingTime = Math.max(1, Math.ceil(wordCount / 200));

let html = note.html || "";
html = html.replace(/\[\[([^\]]+)\]\]/g, (_: string, s: string) =>
  `<a href="/notes/${s.toLowerCase().replace(/\s+/g, '-')}" class="wikilink">${s}</a>`
);

const safeBacklinks = Array.isArray(backlinks) ? backlinks : [];
---

<BaseLayout
  title={note.title}
  notes={notes}
  currentSlug={slug}
  withMath={true}
  toc={note.toc ?? []}
  backlinks={safeBacklinks}
>
  <div id="progress-bar"></div>

  <article>
    <!-- Breadcrumb -->
    <div class="breadcrumb">
      <a href="/">vault</a>
      <span class="sep">/</span>
      <span style="color: var(--text-muted);">{note.title}</span>
    </div>

    <!-- Title -->
    <h1 style="font-family: var(--font-sans); font-weight: 800; font-size: 1.8rem; letter-spacing: -0.02em; line-height: 1.15; color: var(--text); margin: 0 0 12px;">
      {note.title}
    </h1>

    <!-- Tags + reading time -->
    <div style="display: flex; align-items: center; gap: 8px; flex-wrap: wrap; padding-bottom: 20px; margin-bottom: 28px; border-bottom: 1px solid var(--border);">
      {note.tags?.length > 0 && (
        <span style="display: flex; gap: 8px;">
          {note.tags.map((tag: string) => (
            <a
              href={`/tags/${tag}`}
              style="font-family: var(--font-mono); font-size: 12px; color: var(--accent); text-decoration: none;"
            >
              #{tag}
            </a>
          ))}
        </span>
      )}
      {note.tags?.length > 0 && (
        <span style="font-family: var(--font-mono); font-size: 12px; color: var(--text-faint);">&middot;</span>
      )}
      <span style="font-family: var(--font-mono); font-size: 12px; color: var(--text-faint);">
        {readingTime} min read
      </span>
    </div>

    <!-- Content -->
    <div class="prose note-content" set:html={html} />
  </article>

  <script is:inline>
    (function () {
      var bar = document.getElementById("progress-bar");
      if (!bar) return;
      function update() {
        var docH = document.documentElement.scrollHeight - window.innerHeight;
        var pct = docH > 0 ? (window.scrollY / docH) * 100 : 0;
        bar.style.width = pct + "%";
      }
      window.addEventListener("scroll", update, { passive: true });
      update();
    })();
  </script>
</BaseLayout>
