---
export const prerender = false;

import BaseLayout from "../layouts/BaseLayout.astro";

const res = await fetch("http://localhost:3001/api/notes");
const notes = await res.json();
---

<BaseLayout title="Notes" notes={notes} currentPage="notes">
  <p class="section-label mb-2">Notes &mdash; {notes.length} entries</p>

  <div class="flex flex-col">
    {
      notes.map((note: any) => (
        <a href={`/notes/${note.slug}`} class="note-row block" style="padding: 16px 24px;">
          <div class="flex items-start justify-between gap-4">
            <div class="min-w-0 flex-1">
              <!-- Title row with inline tags -->
              <div class="flex items-baseline gap-3 flex-wrap">
                <span style="font-family: var(--font-display); font-weight: 700; font-size: 15px; color: var(--color-text);">
                  {note.title}
                </span>
                {note.tags?.length > 0 && (
                  <span class="flex gap-2">
                    {note.tags.map((tag: string) => (
                      <span style="font-family: var(--font-body); font-size: 11px; color: var(--color-accent);">
                        #{tag}
                      </span>
                    ))}
                  </span>
                )}
              </div>
              <!-- Description row -->
              {note.description && (
                <p style="font-family: var(--font-body); font-size: 12px; color: var(--color-text-muted); margin-top: 4px; line-height: 1.5;">
                  {note.description}
                </p>
              )}
            </div>
            <!-- Reading time / date -->
            {note.date && (
              <span style="font-family: var(--font-body); font-size: 11px; color: var(--color-text-faint); white-space: nowrap; margin-top: 2px;">
                {note.date}
              </span>
            )}
          </div>
        </a>
      ))
    }
  </div>
</BaseLayout>
