---
export const prerender = false;

import BaseLayout from "../layouts/BaseLayout.astro";

const res = await fetch("http://localhost:3001/api/notes");
const notes = await res.json();
---

<BaseLayout title="Notes" notes={notes} currentPage="notes">
  <div class="section-label" style="padding-bottom: 16px; border-bottom: 1px solid var(--border-dim); margin-bottom: 4px;">
    Notes &mdash; {notes.length} entries
  </div>

  <div>
    {
      notes.map((note: any) => (
        <a href={`/notes/${note.slug}`} class="note-row" style="text-decoration: none;">
          <div style="min-width: 0; flex: 1;">
            <span style="font-family: var(--font-sans); font-weight: 600; font-size: 15px; color: var(--text); display: block;">
              {note.title}
            </span>
            {note.description && (
              <p style="font-family: var(--font-mono); font-size: 12px; color: var(--text-muted); margin-top: 3px; line-height: 1.5;">
                {note.description}
              </p>
            )}
          </div>
          {note.tags?.length > 0 && (
            <span style="font-family: var(--font-mono); font-size: 11px; color: var(--accent); white-space: nowrap; text-align: right; flex-shrink: 0;">
              {note.tags.map((tag: string) => `#${tag}`).join(" ")}
            </span>
          )}
        </a>
      ))
    }
  </div>
</BaseLayout>
