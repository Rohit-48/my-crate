---
export const prerender = false;

import BaseLayout from "../../layouts/BaseLayout.astro";

const { tag } = Astro.params;
const API = "http://localhost:3001";

const [tagRes, notesRes] = await Promise.all([
  fetch(`${API}/api/tags/${tag}`),
  fetch(`${API}/api/notes`),
]);

const tagNotes = await tagRes.json();
const notes = await notesRes.json();

if (!Array.isArray(tagNotes)) {
  return new Response(null, { status: 404, statusText: "Not found" });
}
---

<BaseLayout title={`#${tag}`} notes={notes} currentPage="notes">
  <div style="margin-bottom: 24px;">
    <a
      href="/"
      style="font-family: var(--font-mono); font-size: 11px; color: var(--text-faint); display: inline-block; margin-bottom: 12px; transition: color 0.1s;"
      onmouseenter="this.style.color='var(--text)'"
      onmouseleave="this.style.color='var(--text-faint)'"
    >
      &larr; all notes
    </a>
    <h1 style="font-family: var(--font-sans); font-weight: 800; font-size: 1.5rem; color: var(--accent); margin: 0 0 4px;">
      #{tag}
    </h1>
    <p style="font-family: var(--font-mono); font-size: 12px; color: var(--text-faint);">
      {tagNotes.length} note{tagNotes.length !== 1 ? "s" : ""}
    </p>
  </div>

  <div class="section-label" style="padding-bottom: 16px; border-bottom: 1px solid var(--border-dim); margin-bottom: 4px;">
    Notes &mdash; {tagNotes.length} entries
  </div>

  <div>
    {
      tagNotes.map((note: any) => (
        <a href={`/notes/${note.slug}`} class="note-row" style="text-decoration: none;">
          <div style="min-width: 0; flex: 1;">
            <span style="font-family: var(--font-sans); font-weight: 600; font-size: 15px; color: var(--text); display: block;">
              {note.title}
            </span>
            {note.description && (
              <p style="font-family: var(--font-mono); font-size: 12px; color: var(--text-muted); margin-top: 3px; line-height: 1.5;">
                {note.description}
              </p>
            )}
          </div>
          {note.tags?.length > 0 && (
            <span style="font-family: var(--font-mono); font-size: 11px; color: var(--accent); white-space: nowrap; text-align: right; flex-shrink: 0;">
              {note.tags.map((t: string) => `#${t}`).join(" ")}
            </span>
          )}
        </a>
      ))
    }
  </div>
</BaseLayout>
