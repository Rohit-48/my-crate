---
export const prerender = false;

import BaseLayout from "../../layouts/BaseLayout.astro";

const { tag } = Astro.params;
const API = "http://localhost:3001";

const [tagRes, notesRes] = await Promise.all([
  fetch(`${API}/api/tags/${tag}`),
  fetch(`${API}/api/notes`),
]);

const tagNotes = await tagRes.json();
const notes = await notesRes.json();

if (!Array.isArray(tagNotes)) {
  return new Response(null, { status: 404, statusText: "Not found" });
}
---

<BaseLayout title={`#${tag}`} notes={notes} currentPage="notes">
  <div style="margin-bottom: 24px;">
    <h1 style="font-family: var(--font-display); font-weight: 800; font-size: 2rem; letter-spacing: -0.03em; color: var(--color-accent); margin: 0 0 4px;">
      #{tag}
    </h1>
    <p style="font-family: var(--font-body); font-size: 12px; color: var(--color-text-muted);">
      {tagNotes.length} note{tagNotes.length !== 1 ? "s" : ""}
    </p>
  </div>

  <div class="flex flex-col">
    {
      tagNotes.map((note: any) => (
        <a href={`/notes/${note.slug}`} class="note-row block" style="padding: 16px 24px;">
          <div class="flex items-start justify-between gap-4">
            <div class="min-w-0 flex-1">
              <div class="flex items-baseline gap-3 flex-wrap">
                <span style="font-family: var(--font-display); font-weight: 700; font-size: 15px; color: var(--color-text);">
                  {note.title}
                </span>
                {note.tags?.length > 0 && (
                  <span class="flex gap-2">
                    {note.tags.map((t: string) => (
                      <span style={`font-family: var(--font-body); font-size: 11px; color: ${t === tag ? "var(--color-accent)" : "var(--color-text-faint)"};`}>
                        #{t}
                      </span>
                    ))}
                  </span>
                )}
              </div>
              {note.description && (
                <p style="font-family: var(--font-body); font-size: 12px; color: var(--color-text-muted); margin-top: 4px; line-height: 1.5;">
                  {note.description}
                </p>
              )}
            </div>
            {note.date && (
              <span style="font-family: var(--font-body); font-size: 11px; color: var(--color-text-faint); white-space: nowrap; margin-top: 2px;">
                {note.date}
              </span>
            )}
          </div>
        </a>
      ))
    }
  </div>
</BaseLayout>
