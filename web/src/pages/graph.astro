---
export const prerender = false;

import BaseLayout from "../layouts/BaseLayout.astro";
import GraphView from "../components/GraphView.tsx";

const API = "http://localhost:3001";
const [graphRes, notesRes] = await Promise.all([
  fetch(`${API}/api/graph`),
  fetch(`${API}/api/notes`),
]);

const graph = await graphRes.json();
const notes = await notesRes.json();
---

<BaseLayout title="Graph" notes={notes} currentPage="graph">
  <div style="width: 100%; height: 100vh; position: relative; background: var(--bg);">
    <GraphView client:load nodes={graph.nodes} edges={graph.edges} />

    <div style="position: absolute; bottom: 16px; right: 16px; display: flex; flex-direction: column; gap: 4px; z-index: 10;">
      <button
        id="graph-zoom-in"
        style="background: var(--bg-elevated); border: 1px solid var(--border); border-radius: 3px; font-family: var(--font-mono); font-size: 14px; color: var(--text-muted); padding: 6px 10px; cursor: pointer; transition: border-color 0.1s, color 0.1s;"
        aria-label="Zoom in"
      >+</button>
      <button
        id="graph-zoom-out"
        style="background: var(--bg-elevated); border: 1px solid var(--border); border-radius: 3px; font-family: var(--font-mono); font-size: 14px; color: var(--text-muted); padding: 6px 10px; cursor: pointer; transition: border-color 0.1s, color 0.1s;"
        aria-label="Zoom out"
      >&minus;</button>
      <button
        id="graph-reset"
        style="background: var(--bg-elevated); border: 1px solid var(--border); border-radius: 3px; font-family: var(--font-mono); font-size: 14px; color: var(--text-muted); padding: 6px 10px; cursor: pointer; transition: border-color 0.1s, color 0.1s;"
        aria-label="Reset view"
      >&#x2299;</button>
    </div>
  </div>

  <style>
    button:hover {
      border-color: var(--accent-border) !important;
      color: var(--text) !important;
    }
  </style>
</BaseLayout>
