# MY-CRATE Configuration
# Copy this to .env and fill in your values
# cp .env.example .env

# ── Webhook ────────────────────────────────────────────────
# Secret string to verify GitHub webhook payloads
# Generate one: openssl rand -hex 32
WEBHOOK_SECRET=changeme

# ── Ports ──────────────────────────────────────────────────
API_PORT=3001
WEB_PORT=4321
WEBHOOK_PORT=3002

# ── System user ────────────────────────────────────────────
# The user that will run the systemd services
# Default: current user
SERVICE_USER=void
